{
  "manifest_version": 3,
  "name": "SpeakAI Quick Lookup",
  "version": "1.0.0",
  "description": "Look up and save English words on any website — powered by your SpeakAI learning app.",
  "permissions": ["contextMenus", "storage", "activeTab"],
  "host_permissions": ["https://api.dictionaryapi.dev/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "SpeakAI Quick Lookup" },
  "content_scripts": [{ "matches": ["<all_urls>"], "js": ["content.js"] }],
  "icons": { "128": "icon.png" }
}
