# Template — copy to .env.local and fill in. .env.local is gitignored.

# Supabase
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Renderer-side (Vite exposes VITE_* prefix to the browser)
VITE_USE_SUPABASE=0
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Cloud AI providers (filled per-user via Settings → AI, not here)
# Optional service-level fallback only:
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
