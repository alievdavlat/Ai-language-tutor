# Template — copy to .env.local and fill in. .env.local is gitignored.

# Supabase
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Renderer-side (Vite exposes VITE_* prefix to the browser)
VITE_USE_SUPABASE=0
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ── Realtime / live slice (multiplayer quiz, Meet, live streaming, group) ────
# With NONE of these set, the live pages run in same-machine demo mode:
#   • signaling/presence uses the BroadcastChannel API (syncs only between
#     windows/tabs on this one machine)
#   • video uses a peer-to-peer WebRTC mesh with public STUN (works on the
#     same machine / open networks)
# To make rooms real across devices, turn on Supabase Realtime (just set
# VITE_USE_SUPABASE=1 above with the URL + anon key — no extra tables needed).
#
# TURN relay — required for reliable video across strict NATs / firewalls.
# VITE_TURN_URL=turn:turn.example.com:3478
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=
#
# LiveKit SFU — optional scale path for large live audiences (100s of viewers).
# Needs a running LiveKit server + a token-minting endpoint (see docs/REALTIME.md).
# VITE_LIVEKIT_URL=wss://your-livekit-host
# VITE_LIVEKIT_TOKEN_ENDPOINT=https://your-app/api/livekit-token

# Cloud AI providers (filled per-user via Settings → AI, not here)
# Optional service-level fallback only:
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
